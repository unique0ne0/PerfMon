<Window x:Class="PerfMonCS.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PerfMon 설정"
        Width="410" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="12"
        SnapsToDevicePixels="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="Tabs" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnOk"     Content="확인"   Width="78" Height="26" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button x:Name="BtnApply"  Content="적용"   Width="78" Height="26" Margin="0,0,8,0" Click="OnApply"/>
            <Button x:Name="BtnCancel" Content="취소"   Width="78" Height="26" Margin="0,0,8,0" IsCancel="True"  Click="OnCancel"/>
            <Button x:Name="BtnReset"  Content="초기화" Width="78" Height="26" Click="OnReset"/>
        </StackPanel>
    </Grid>
</Window>
